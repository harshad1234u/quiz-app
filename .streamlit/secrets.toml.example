# ──────────────────────────────────────────────────────────────────────────────
# Streamlit Secrets Configuration Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your actual values.
# NEVER commit secrets.toml to version control!

# ── Supabase Configuration ──────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
#
# HOW TO FIND YOUR CREDENTIALS:
#   1. Go to https://supabase.com and sign in
#   2. Open your project (or create one)
#   3. Click "Settings" (gear icon) in the sidebar
#   4. Click "API" under "Configuration"
#   5. Copy "Project URL" → paste as SUPABASE_URL
#   6. Copy "anon public" key → paste as SUPABASE_KEY
#
# IMPORTANT:
#   - Use the FULL project URL (e.g., https://abcdefgh.supabase.co)
#   - Do NOT append /rest/v1/ to the URL
#   - Use the "anon public" key, NOT the "service_role" key
#
SUPABASE_URL = ""
SUPABASE_KEY = ""

# ── NVIDIA NIM API Configuration ────────────────────────────────────────────────
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY = ""
NVIDIA_BASE_URL = "https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL = "meta/llama-3.3-70b-instruct"
# Alternative models:
#   meta/llama-3.1-8b-instruct   (faster, cheaper)
#   mistralai/mistral-7b-instruct-v0.3

# ── Google OAuth Configuration (Optional) ────────────────────────────────────────
# For Google Sign-In support:
#   1. Get credentials from: https://console.cloud.google.com/apis/credentials
#   2. Also enable Google as a provider in Supabase Dashboard → Authentication → Providers
#   3. Set the redirect URI to your Streamlit Cloud URL
#
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""
GOOGLE_REDIRECT_URI = "https://your-app.streamlit.app/Login"

# ── Application Secrets ────────────────────────────────────────────────────────
# Generate a secure key for your application (used for session signing, etc.)
APP_SECRET_KEY = ""

# ──────────────────────────────────────────────────────────────────────────────
# For Streamlit Cloud deployment, add these secrets via:
# Settings → Secrets management → Add secret
# ──────────────────────────────────────────────────────────────────────────────
