# ──────────────────────────────────────────────────────────────────────────────
# Streamlit Secrets Configuration Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your actual values.
# NEVER commit secrets.toml to version control!

# ── MySQL Database Configuration ────────────────────────────────────────────────
MYSQL_HOST = "localhost"
MYSQL_PORT = 3306
MYSQL_USER = "root"
MYSQL_PASSWORD = ""
MYSQL_DATABASE = "quiz_app"

# ── NVIDIA NIM API Configuration ────────────────────────────────────────────────
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY = ""
NVIDIA_BASE_URL = "https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL = "meta/llama-3.3-70b-instruct"
# Alternative models:
#   meta/llama-3.1-8b-instruct   (faster, cheaper)
#   mistralai/mistral-7b-instruct-v0.3

# ── Google OAuth Configuration ──────────────────────────────────────────────────
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""

# ── Application Secrets ────────────────────────────────────────────────────────
# Generate a secure key for your application
APP_SECRET_KEY = ""

# ──────────────────────────────────────────────────────────────────────────────
# For Streamlit Cloud deployment, add these secrets via:
# Settings → Secrets management → Add secret
# ──────────────────────────────────────────────────────────────────────────────
